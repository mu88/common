{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "description": "mu88's default preset",
  "extends": [
    "config:base",
    "group:all",
    ":semanticCommitTypeAll(chore)"
  ],
  "logLevelRemap": [
    {
      "matchMessage": "*as they do not have a releaseTimestamp and we're running with minimumReleaseAgeBehaviour=timestamp-required*",
      "newLogLevel": "error"
    },
    {
      "matchMessage": "*Preset fetch error*",
      "newLogLevel": "error"
    },
    {
      "matchMessage": "*Repository has invalid config*",
      "newLogLevel": "error"
    },
    {
      "matchMessage": "*did not have a releaseTimestamp, but as we're running with minimumReleaseAgeBehaviour=timestamp-optional*",
      "newLogLevel": "info"
    }
  ],
  "schedule": [
    "* 7-17 * * 1"
  ],
  "automergeSchedule": [
    "* 7-17 * * 1"
  ],
  "mode": "full",
  "minimumReleaseAge": "14 days",
  "automerge": true,
  "automergeType": "branch",
  "osvVulnerabilityAlerts": true,
  "vulnerabilityAlerts": {
    "enabled": true,
    "automerge": true,
    "labels": [
      "security"
    ],
    "vulnerabilityFixStrategy": "lowest",
    "schedule": [
      "at any time"
    ],
    "automergeSchedule": [
      "at any time"
    ],
    "minimumReleaseAge": null
  },
  "prHourlyLimit": 0,
  "prConcurrentLimit": 0,
  "branchConcurrentLimit": 0,
  "packageRules": [
    {
      "description": "Immediately merge updates of my own NuGet package as I'm in charge of those.",
      "matchPackageNames": [
        "mu88.Shared"
      ],
      "minimumReleaseAge": "0 minutes"
    },
    {
      "description": "Immediately merge new digests from mu88/common as they don't have a timestamp",
      "matchDepNames": [
        "mu88/common"
      ],
      "matchUpdateTypes": [
        "digest"
      ],
      "minimumReleaseAge": "0 minutes"
    },
    {
      "description": "Wait with non-major updates of .NET SDK and runtime (global.json and Docker images) so that it is likely to be installed on all dev machines, too",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ],
      "matchPackageNames": [
        "dotnet-sdk",
        "dotnet-runtime",
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/aspnet",
        "mcr.microsoft.com/dotnet/runtime",
        "mcr.microsoft.com/dotnet/runtime-deps"
      ],
      "minimumReleaseAge": "21 days"
    },
    {
      "description": "Major updates of .NET SDK and runtime will be done manually",
      "matchUpdateTypes": [
        "major"
      ],
      "matchPackageNames": [
        "dotnet-sdk",
        "dotnet-runtime",
        "mcr.microsoft.com/dotnet/sdk",
        "mcr.microsoft.com/dotnet/aspnet",
        "mcr.microsoft.com/dotnet/runtime",
        "mcr.microsoft.com/dotnet/runtime-deps",
        "Microsoft.AspNetCore*",
        "Microsoft.Bcl*",
        "Microsoft.EntityFrameworkCore*",
        "Microsoft.Extensions.*",
        "System.Text.Json"
      ],
      "enabled": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": [
        "^\\S*\\.csproj$"
      ],
      "matchStrings": [
        "<ContainerBaseImage>(?<packageName>\\S+):(?<currentValue>\\S+)<\/ContainerBaseImage>"
      ],
      "datasourceTemplate": "docker"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^\\S*\\.csproj$"
      ],
      "matchStrings": [
        "<CustomContainerBaseImageVersion>(?<currentValue>\\S+)<\/CustomContainerBaseImageVersion>"
      ],
      "datasourceTemplate": "dotnet-version",
      "packageNameTemplate": "dotnet-runtime"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "^\\S*\\.devcontainer\\/devcontainer\\.json$"
      ],
      "matchStrings": [
        "\"image\":\\s*\"\\S*mu88\\/devcontainers-dotnet\\S*:sdk-(?<currentValue>\\d+\\.\\d+\\.\\d+)\\S*"
      ],
      "datasourceTemplate": "dotnet-version",
      "packageNameTemplate": "dotnet-sdk"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/|\\.)([Dd]ocker|[Cc]ontainer)file$",
        "(^|/)([Dd]ocker|[Cc]ontainer)file[^/]*$",
        "(^|/)(?:docker-)?compose[^/]*\\.ya?ml$"
      ],
      "matchStrings": [
        "\\S*mcr\\.microsoft\\.com\\/dotnet\\/aspnet:(?<currentValue>\\d+(\\.\\d+)?(\\.\\d+)?).*",
        "\\S*mcr\\.microsoft\\.com\\/dotnet\\/runtime:(?<currentValue>\\d+(\\.\\d+)?(\\.\\d+)?).*",
        "\\S*mcr\\.microsoft\\.com\\/dotnet\\/runtime-deps:(?<currentValue>\\d+(\\.\\d+)?(\\.\\d+)?).*"
      ],
      "datasourceTemplate": "dotnet-version",
      "packageNameTemplate": "dotnet-runtime"
    },
    {
      "customType": "regex",
      "fileMatch": [
        "(^|/|\\.)([Dd]ocker|[Cc]ontainer)file$",
        "(^|/)([Dd]ocker|[Cc]ontainer)file[^/]*$",
        "(^|/)(?:docker-)?compose[^/]*\\.ya?ml$"
      ],
      "matchStrings": [
        "\\S*mcr\\.microsoft\\.com\\/dotnet\\/sdk:(?<currentValue>\\d+(\\.\\d+)?(\\.\\d+)?).*"
      ],
      "datasourceTemplate": "dotnet-version",
      "packageNameTemplate": "dotnet-sdk"
    }
  ]
}
