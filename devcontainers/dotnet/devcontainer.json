{
  "name": "C# (.NET)",
  "image": "mcr.microsoft.com/devcontainers/base:noble", // using base image + dotnet feature to pin an exact SDK version (see https://github.com/devcontainers/templates/issues/330)
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/dotnet:2": {
      "version": "${localEnv:DOTNET_SDK_VERSION:10.0.203}"
    },
    "ghcr.io/devcontainers/features/powershell:2": {}
  },
  "postCreateCommand": "git clean -xdf -e '.idea' -e '*.DotSettings.user'; dotnet dev-certs https --trust; dotnet tool restore; dotnet restore", // see https://github.com/microsoft/vscode-remote-release/issues/9099
  "customizations": {
    "vscode": {
      "extensions": [
        "eriklynd.json-tools",
        "github.vscode-github-actions",
        "github.copilot-chat",
        "github.copilot",
        "ms-dotnettools.csdevkit",
        "ms-vscode.powershell",
        "ms-vscode.vscode-loc-en"
      ],
      "settings": {
        "git.allowForcePush": true,
        "locale": "en",
        "powershell.developerTools.enableTelemetry": false,
        "terminal.integrated.defaultProfile.linux": "pwsh",
        "terminal.integrated.profiles.linux": {
          "pwsh": {
            "path": "/usr/bin/pwsh",
            "args": [
              "-NoLogo"
            ]
          }
        },
        "workbench.startupEditor": "none"
      }
    }
  },
  "containerEnv": {
    "DOTNET_CLI_TELEMETRY_OPTOUT": "1"
  },
  "containerUser": "vscode" // see https://github.com/orgs/community/discussions/155456
}
