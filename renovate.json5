{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "github>mu88/common//renovate/default.json5"
  ],
  "devcontainer": {
    "managerFilePatterns": [
      "/^devcontainers\\/\\S+\\/devcontainer\\.json$/"
    ]
  },
  "packageRules": [
    {
      "description": "Unfortunately, these packages do not return a release timestamp. In Renovate v43, 'minimumReleaseAgeBehaviour' cannot be used inside packageRules (no 'mergeable: true' in schema), so we set 'minimumReleaseAge: null' to disable the age check entirely, which also bypasses the timestamp requirement. Once upgraded to v44+, replace 'minimumReleaseAge: null' with 'minimumReleaseAgeBehaviour: \"timestamp-optional\"' in this packageRule.",
      "matchPackageNames": [
        "ghcr.io/devcontainers/features/powershell",
        "ghcr.io/renovatebot/renovate",
        "mcr.microsoft.com/devcontainers/typescript-node",
        "mcr.microsoft.com/dotnet/sdk"
      ],
      "minimumReleaseAge": null
    },
    {
      "description": "Non-major updates of .NET SDK can be integrated into dev containers and their build workflow immediately after the release, because these dev containers won't be immediately used by downstream repositories, i.e. it's safe to already have them.",
      "matchUpdateTypes": [
        "minor",
        "patch"
      ],
      "matchPackageNames": [
        "dotnet-sdk"
      ],
      "matchFileNames": [
        "devcontainers/**",
        ".github/workflows/_internal-build-devcontainers.yml"
      ],
      "minimumReleaseAge": "1 days",
      "automerge": true,
      "automergeType": "branch"
    }
  ],
  "customManagers": [
    {
      "description": "The .NET SDK default version when building the .NET dev container in case no version is provided (e.g. not within a GitHub Action or forgotten to set the environment variable)",
      "customType": "regex",
      "managerFilePatterns": [
        "/\\S*\\/devcontainer\\.json/"
      ],
      "matchStrings": [
        "\\s*\"dotnet_sdk_version\":\\s*\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\"", // for .devcontainer/devcontainer.json
        "\\s*\"version\":\\s*\"\\${localEnv:DOTNET_SDK_VERSION:(?<currentValue>\\d+\\.\\d+\\.\\d+)}\"", // for devcontainers/dotnet/devcontainer.json
        "\\s*\"DOTNET_SDK_VERSION\":\\s*\"\\${localEnv:DOTNET_SDK_VERSION:(?<currentValue>\\d+\\.\\d+\\.\\d+)}\"", // for devcontainers/dotnet-playwright/devcontainer.json
        "DOTNET_SDK_VERSION=\"(?<currentValue>\\d+\\.\\d+\\.\\d+)\"" // for devcontainers/dotnet-playwright/Dockerfile
      ],
      "datasourceTemplate": "dotnet-version",
      "packageNameTemplate": "dotnet-sdk"
    },
    {
      "description": "The .NET SDK default for regular (i.e. not manually triggered) GitHub Action runs → see https://github.com/renovatebot/renovate/discussions/40905",
      "customType": "regex",
      "managerFilePatterns": [
        "/\\.github\\/workflows\\/_internal-build-devcontainers\\.yml/"
      ],
      "matchStrings": [
        "\\s*DEFAULT_dotnet-sdk-version:\\s*(?<currentValue>\\d+\\.\\d+\\.\\d+)\\S*"
      ],
      "datasourceTemplate": "dotnet-version",
      "packageNameTemplate": "dotnet-sdk"
    },
    {
      "description": "Track the Renovate Docker image version used in GitHub Actions workflows",
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github\\/workflows\\/renovate\\.yml$/",
        "/^\\.github\\/workflows\\/validate-renovate-config\\.yml$/"
      ],
      "matchStrings": [
        "RENOVATE_VERSION:\\s*\"(?<currentValue>[\\d.]+)\""
      ],
      "datasourceTemplate": "docker",
      "packageNameTemplate": "ghcr.io/renovatebot/renovate"
    }
  ]
}
